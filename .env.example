# For local dev with the Vercel CLI (`vercel dev`):
# Set this in Vercel project environment variables instead.
# The serverless function at api/groq.js reads it from process.env.
# GROQ_API_KEY=your_groq_api_key_here

# For plain `vite dev` without Vercel CLI (local testing only):
# NEVER set this in production — it ships the key to the browser.
# VITE_GROQ_API_KEY_DEV_ONLY=your_groq_api_key_here
